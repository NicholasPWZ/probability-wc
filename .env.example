# --- Gemini (optional) ---
# Only needed for the "Let Gemini analyze this match" button. The app and its
# statistical engine work fully without a key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Data source / tournament (FotMob) ---
# World Cup = FotMob league 77; season defaults to 2026 (verified).
LEAGUE_ID=77
SEASON=2026

# --- Scraping behaviour ---
# How many recent finished matches per team to sample for the form/stat model.
RECENT_MATCHES=6
# Max concurrent requests to SofaScore (keep modest to avoid Cloudflare rate-limits).
MAX_CONCURRENCY=4
# On-disk response cache TTL in seconds (1h). Fixtures use a shorter internal TTL.
CACHE_TTL=3600
# Directory for the on-disk HTTP cache.
CACHE_DIR=.cache

# --- Display ---
# Timezone used to group matches by day and show kickoff times.
DISPLAY_TZ=America/Sao_Paulo
